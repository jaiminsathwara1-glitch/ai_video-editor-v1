# ─────────────────────────────────────────────────────────────────────────────
#  Environment Configuration — copy to .env and fill in values
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                       # development | production
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
LOG_LEVEL=INFO

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./storage/uploads
THUMBNAIL_DIR=./storage/thumbnails
EXPORT_DIR=./storage/exports
TEMP_DIR=./storage/temp
MAX_UPLOAD_SIZE_GB=20                     # per-file limit in GB

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./storage/db/videoedit.db

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── FFmpeg ────────────────────────────────────────────────────────────────────
FFMPEG_BINARY=ffmpeg                      # full path if not on PATH
FFPROBE_BINARY=ffprobe

# ── AI / LLM ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini                  # only for text summarisation
WHISPER_MODEL=base                        # tiny | base | small | medium | large

# ── Thumbnail ─────────────────────────────────────────────────────────────────
THUMBNAIL_WIDTH=320
THUMBNAIL_HEIGHT=180
THUMBNAIL_COUNT=5                         # per-clip sprite sheet frames

# ── Chunked Upload ────────────────────────────────────────────────────────────
CHUNK_SIZE_MB=10                          # client-side chunk size hint

# ── Performance ───────────────────────────────────────────────────────────────
CELERY_CONCURRENCY=4
ANALYSIS_TIMEOUT_SECONDS=3600
